# --- Auth -------------------------------------------------------------
# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-string

# --- Data directory (optional) ------------------------------------------
# Where the SQLite file (data/app.sqlite) is stored. Leave unset for local
# dev (defaults to ./data). On a host with a mounted persistent volume
# (e.g. Railway, Render paid plans), set this to the volume's mount path
# so writes survive restarts/redeploys, e.g. DATA_DIR=/data
DATA_DIR=

# --- AI narrative (optional) -------------------------------------------
# If set, the AI insights endpoint calls the Anthropic API to turn the
# rule-based analytics (accuracy, pace, weak points) into a short written
# summary. Without it, a template-based Japanese summary is used instead —
# the numbers, charts and recommendations all still work.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Stripe billing (optional) -----------------------------------------
# Without these, /billing shows plan info but checkout returns a clear
# "not configured" message instead of erroring.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_FAMILY_20=
STRIPE_WEBHOOK_SECRET=
APP_URL=http://localhost:3000
